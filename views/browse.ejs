<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Browse Tasks - Community Help</title>
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="stylesheet" href="/css/browse.css">
    <link rel="stylesheet" href="/css/modal.css">
</head>
<body data-theme="<%= user.theme || 'neutral' %>">
    <nav class="navbar">
        <div class="nav-container">
            <div class="nav-brand">
                <a href="/dashboard" class="brand-link">
                    <h1>Community Help</h1>
                    <p><%= user.city %></p>
                </a>
            </div>
            <ul class="nav-menu">
                <li><a href="/browse" class="nav-link active">Browse Tasks</a></li>
                <li><a href="/create-task" class="nav-link">Create Task</a></li>
                <li><a href="/my-tasks" class="nav-link">My Tasks</a></li>
                <li><a href="/profile" class="nav-link">Profile</a></li>
                <li><a href="/logout" class="nav-link logout-btn">Sign Out</a></li>
            </ul>
        </div>
    </nav>

    <div class="container">
        <div class="browse-header">
            <h1>Browse Tasks</h1>
            <p>Tasks from <%= currentCity %> appear first</p>

            <div class="filter-bar">
                <input 
                    type="text" 
                    id="searchInput" 
                    placeholder="Search tasks..." 
                    class="search-input"
                >
                <select id="categoryFilter" class="filter-select">
                    <option value="">All Categories</option>
                    <option value="Tutoring">Tutoring</option>
                    <option value="Help with Project">Help with Project</option>
                    <option value="Job">Job</option>
                    <option value="Service">Service</option>
                    <option value="General">General</option>
                </select>
            </div>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-error"><%= error %></div>
        <% } %>

        <div id="tasksContainer" class="tasks-grid">
            <% if (tasks && tasks.length > 0) { %>
                <% tasks.forEach(task => { %>
                    <div class="task-card" data-category="<%= task.category || 'General' %>">
                        <div class="task-header">
                            <div>
                                <h3><%= task.title %></h3>
                                <p class="task-category"><%= task.category || 'General' %></p>
                            </div>
                            <% if (task.pay) { %>
                                <div class="task-pay">$<%= task.pay.toFixed(2) %></div>
                            <% } else { %>
                                <div class="task-pay free">Free</div>
                            <% } %>
                        </div>

                        <p class="task-description"><%= task.description.substring(0, 120) %>...</p>

                        <div class="task-footer">
                            <div class="task-meta">
                                <span class="task-location">📍 <%= task.city %></span>
                                <span class="task-creator">By <%= task.creator_name %></span>
                            </div>
                            <a href="/tasks/<%= task.id %>" class="btn btn-small">View Task</a>
                        </div>

                        <div class="task-report">
                            <button class="report-btn" data-task-id="<%= task.id %>" title="Report suspicious listing">
                                🚩 <%= task.report_count || 0 %>/5
                            </button>
                            <span class="report-warning">False reports = account termination</span>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="no-tasks">
                    <p>No tasks found. <a href="/create-task">Create one!</a></p>
                </div>
            <% } %>
        </div>
    </div>

    <!-- Report Modal -->
    <div id="reportModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Report Suspicious Listing</h2>
                <button class="modal-close" id="closeReportModal">&times;</button>
            </div>
            <div class="modal-body">
                <p class="modal-warning">⚠️ <strong>False reporting will result in account termination</strong></p>
                <div class="form-group">
                    <label for="reportReason">Reason for Report *</label>
                    <select id="reportReason" required>
                        <option value="">Select a reason</option>
                        <option value="Spam">Spam or Scam</option>
                        <option value="Inappropriate Content">Inappropriate Content</option>
                        <option value="Harassment">Harassment or Threats</option>
                        <option value="Illegal Activity">Illegal Activity</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="reportDetails">Additional Details</label>
                    <textarea id="reportDetails" placeholder="Please provide any additional information..." rows="4"></textarea>
                </div>
                <div id="reportError" class="alert alert-error" style="display: none;"></div>
                <div id="reportSuccess" class="alert alert-success" style="display: none;"></div>
            </div>
            <div class="modal-footer">
                <button id="cancelReport" class="btn btn-secondary">Cancel</button>
                <button id="submitReport" class="btn btn-danger">Submit Report</button>
            </div>
        </div>
    </div>

    <script src="/js/browse.js"></script>
</body>
</html>
